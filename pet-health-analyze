<script>
    // Chart 1: PIMS Coverage (Bar)
    const ctx1 = document.getElementById('pimsChart').getContext('2d');
    new Chart(ctx1, {
        type: 'bar',
        data: {
            labels: ['인투펫 (국내 최대)', 'WAAL (우리엔)', 'PetDesk (미국)', 'Pulse (글로벌)'],
            datasets: [{
                label: '제휴 및 연동 병원 수 (단위: 개소)',
                data: [2000, 1500, 1800, 1200],
                backgroundColor: ['#2563eb', '#3b82f6', '#60a5fa', '#93c5fd'],
                borderRadius: 12
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false }
            },
            scales: {
                y: { beginAtZero: true, grid: { borderDash: [5, 5], color: '#f1f5f9' } },
                x: { grid: { display: false } }
            }
        }
    });

    // Chart 2: Service Strengths (Radar)
    const ctx2 = document.getElementById('featureRadar').getContext('2d');
    new Chart(ctx2, {
        type: 'radar',
        data: {
            labels: ['데이터 정확도', '병원 접근성', '부가 서비스(케어 연계)', '비용 효율성', '실시간성'],
            datasets: [{
                label: 'PIMS 연동형 (인투펫 등)',
                data: [95, 60, 85, 90, 95],
                borderColor: '#2563eb',
                backgroundColor: 'rgba(37, 99, 235, 0.1)',
                borderWidth: 2
            }, {
                label: '비정형/스캔형 (티티케어 등)',
                data: [75, 95, 80, 85, 80],
                borderColor: '#f59e0b',
                backgroundColor: 'rgba(245, 158, 11, 0.1)',
                borderWidth: 2
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                r: {
                    angleLines: { color: '#e2e8f0' },
                    grid: { color: '#e2e8f0' },
                    pointLabels: { font: { size: 11, weight: '600' }, color: '#475569' },
                    suggestedMin: 50,
                    suggestedMax: 100
                }
            },
            plugins: {
                legend: { position: 'bottom', labels: { boxWidth: 12 } }
            }
        }
    });

    // Simulation Logic
    function runSimulation() {
        const target = document.getElementById('target').value;
        const tech = document.getElementById('tech').value;
        const revenue = document.getElementById('revenue').value;
        const moat = document.getElementById('moat').value;

        let score = 30; // base score

        // 1. Target Scoring
        if (target === 'chronic') score += 20; // High margin pain point
        else if (target === 'breed') score += 18; // Very customized niche
        else if (target === 'puppy') score += 12; // Moderate churn risk
        else score += 5; // Red ocean high market cost

        // 2. Tech Scoring
        if (tech === 'ocr') score += 20; // Fast entry, circumvents PIMS monopoly
        else if (tech === 'iot') score += 15; // Hard to scale hardware but high barrier
        else if (tech === 'pims') score += 8; // Super hard for latecomer
        else score += 3; // Weak barrier

        // 3. Revenue Scoring
        if (revenue === 'insurance') score += 20; // Best synergy with healthcare
        else if (revenue === 'kibble') score += 17; // Direct monetization loop
        else if (revenue === 'sub') score += 12; // Tough to pay for unless highly high quality
        else score += 5; // Ad-based model has lower profit margin for niche

        // 4. Moat / USP Scoring
        if (moat === 'vet') score += 20; // Great solution for urgent care anxiety
        else if (moat === 'privacy') score += 15; // High tech differentiator
        else if (moat === 'family') score += 15; // Great lock-in for family
        else score += 4; // Design alone cannot survive

        // Keep inside reasonable bounds
        if (score > 95) score = 95;
        if (score < 30) score = 30;

        // Animate Score Bar
        const bar = document.getElementById('score-bar');
        const text = document.getElementById('score-text');
        
        bar.style.width = score + '%';
        text.innerText = score + '%';

        // Apply colors based on score
        if (score >= 80) {
            bar.className = "h-full transition-all duration-1000 bg-emerald-500";
            text.className = "text-2xl font-black text-emerald-500 animate-pulse";
        } else if (score >= 60) {
            bar.className = "h-full transition-all duration-1000 bg-blue-500";
            text.className = "text-2xl font-black text-blue-500";
        } else {
            bar.className = "h-full transition-all duration-1000 bg-amber-500";
            text.className = "text-2xl font-black text-amber-500";
        }

        // Generate tailored analysis report
        let feedbackHTML = `
            <div class="space-y-4 text-slate-700">
                <p class="font-bold text-slate-900 border-b pb-2">🎯 전략적 핵심 리포트</p>
        `;

        // Strength Feedback
        feedbackHTML += `<div class="bg-emerald-50 border border-emerald-100 p-4 rounded-xl text-xs md:text-sm text-emerald-800">`;
        feedbackHTML += `<strong class="block mb-1 text-emerald-900">✔️ 뛰어난 진입 소구점</strong>`;
        if (target === 'chronic' || target === 'breed') {
            feedbackHTML += `기존의 인투펫, 티티케어가 다루지 못했던 고부가가치 타겟을 선점했습니다. 이 시장은 의료비 지출 규모가 큰 우량 고객층이므로 락인(Lock-in) 효과가 큽니다.`;
        } else {
            feedbackHTML += `보편적인 고객 타겟을 선택하셨습니다. 매력적이지만 초기 마케팅 비용이 거대 플랫폼 대비 상당히 지출될 수 있습니다.`;
        }
        feedbackHTML += `</div>`;

        // Risk & Weakness Feedback
        feedbackHTML += `<div class="bg-amber-50 border border-amber-100 p-4 rounded-xl text-xs md:text-sm text-amber-800">`;
        feedbackHTML += `<strong class="block mb-1 text-amber-900">⚠️ 잠재적 위협 요인</strong>`;
        if (tech === 'pims') {
            feedbackHTML += `병원 차트(PIMS) 연동 시도는 막강한 진입장벽입니다. 이미 인투펫과 WAAL이 시장 제휴 병원들의 90% 이상을 차지하고 있어 신규 병원이 귀하의 SDK를 탑재할 매력도가 매우 낮습니다. 우회 데이터 획득 전략(OCR 등)을 강력히 권장합니다.`;
        } else if (tech === 'manual') {
            feedbackHTML += `사용자의 수동 기입에 의존하는 데이터 수집은 극심한 피로를 유발해 초기 1개월 내 이탈율이 70%가 넘어섭니다. 반드시 카메라 및 자동화 수집 수단을 결합하세요.`;
        } else {
            feedbackHTML += `OCR과 음성 AI 혹은 IoT 센서 기반의 우회 데이터 획득 경로는 매우 현명한 전술입니다. 병원의 물리적 허가 장벽을 넘는 효과적인 돌파구입니다.`;
        }
        feedbackHTML += `</div>`;

        // Strategic Next Steps
        feedbackHTML += `<div class="bg-blue-50 border border-blue-100 p-4 rounded-xl text-xs md:text-sm text-blue-800">`;
        feedbackHTML += `<strong class="block mb-1 text-blue-900">💡 향후 밸류 업그레이드 조언</strong>`;
        if (revenue === 'insurance') {
            feedbackHTML += `펫보험 결합을 선택한 것은 환상적입니다. 금융 회사들과의 API 동맹을 통해 실시간 청구 및 프리미엄 할인을 제공하는 것이 핵심 마일스톤이 될 것입니다.`;
        } else if (revenue === 'kibble') {
            feedbackHTML += `식사 처방 커미션 모델은 고지혈증, 간 수치 상승 등 정밀 병리 데이터와 원터치 정기구독 루프가 완벽히 결합되어야 효율을 발휘합니다.`;
        } else {
            feedbackHTML += `광고와 단순 구독 방식은 데이터의 가치를 낮게 평가하는 경향이 있습니다. 실질적인 커머스 및 금융 혜택으로의 변환을 염두에 두십시오.`;
        }
        feedbackHTML += `</div></div>`;

        document.getElementById('result-text-container').innerHTML = feedbackHTML;

        // Generate Badges
        const badgeContainer = document.getElementById('badge-container');
        badgeContainer.classList.remove('hidden');
        
        let badges = '';
        if (score >= 80) {
            badges += `<span class="bg-emerald-100 text-emerald-800 text-xs font-bold px-3 py-1 rounded-full border border-emerald-200">✨ 유니콘 가능성</span>`;
            badges += `<span class="bg-indigo-100 text-indigo-800 text-xs font-bold px-3 py-1 rounded-full border border-indigo-200">🚀 강력한 모트 보유</span>`;
        } else if (score >= 60) {
            badges += `<span class="bg-blue-100 text-blue-800 text-xs font-bold px-3 py-1 rounded-full border border-blue-200">📈 안정적 진입 가능</span>`;
            badges += `<span class="bg-slate-100 text-slate-800 text-xs font-bold px-3 py-1 rounded-full border border-slate-200">🛠️ 부분 수정 필요</span>`;
        } else {
            badges += `<span class="bg-amber-100 text-amber-800 text-xs font-bold px-3 py-1 rounded-full border border-amber-200">⚠️ 전면 재설계 권장</span>`;
            badges += `<span class="bg-red-100 text-red-800 text-xs font-bold px-3 py-1 rounded-full border border-red-200">🛑 병목 구간 봉착</span>`;
        }
        badgeContainer.innerHTML = badges;
    }
</script>

